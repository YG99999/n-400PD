# ── CitizenFlow Environment Variables ──

# Server port (defaults to 5000)
PORT=5000
SESSION_SECRET=replace-me
APP_URL=http://localhost:5000
DATA_DIR=.data
PUBLIC_DEMO_ENABLED=true
SECURE_COOKIES=false
INLINE_DOCUMENT_PROCESSING=true
PAYMENT_AMOUNT_CENTS=14900
SUPPORTED_USCIS_EDITION=01/20/25
STRIPE_PRICE_NAME=CitizenFlow N-400 preparation

# ── Future integrations (not required for local/demo mode) ──

# Supabase (database + auth + storage)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_STORAGE_BUCKET=citizenflow-documents

# Google Gemini (AI conversation engine)
# GEMINI_API_KEY=your-gemini-api-key

# Stripe (payments)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# ElevenLabs (text-to-speech)
# ELEVENLABS_API_KEY=your-api-key
# ELEVENLABS_VOICE_ID=aria

# Database URL (for production with Drizzle ORM)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Frontend auth
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
