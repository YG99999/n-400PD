# CitizenFlow production env template for Vercel import
# Replace every placeholder before importing into Vercel.

NODE_ENV=production
PORT=5000
APP_URL=https://your-production-domain.vercel.app
SESSION_SECRET=replace-with-a-long-random-secret

# Runtime behavior
PUBLIC_DEMO_ENABLED=false
SECURE_COOKIES=true
INLINE_DOCUMENT_PROCESSING=false
ALLOW_PRODUCTION_FALLBACKS=false
ALLOW_LOCAL_STORAGE_IN_PRODUCTION=false
DATA_DIR=.data
DOCUMENT_WORKER_POLL_MS=3000

# Product configuration
PAYMENT_AMOUNT_CENTS=14900
SUPPORTED_USCIS_EDITION=01/20/25
STRIPE_PRICE_NAME=CitizenFlow N-400 preparation

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=citizenflow-documents

# Frontend auth
VITE_APP_URL=https://your-production-domain.vercel.app
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Stripe
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID=price_replace_me

# Optional integrations
GEMINI_API_KEY=optional-gemini-api-key
ELEVENLABS_API_KEY=optional-elevenlabs-api-key
ELEVENLABS_AGENT_ID=agent_5501kkjmqrzreharr1hggpa4jpyx
ELEVENLABS_WEBHOOK_SECRET=optional-webhook-secret
ELEVENLABS_SERVER_LOCATION=us

# Optional internal testing bypass
TEST_FLOW_BYPASS_ENABLED=false
VITE_ENABLE_FULL_FLOW_BYPASS=false

# Optional direct Postgres connection
DATABASE_URL=postgresql://user:password@host:5432/dbname
