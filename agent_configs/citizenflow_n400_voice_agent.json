{
  "name": "CitizenFlow N-400 Voice Intake",
  "conversation_config": {
    "asr": {
      "quality": "high",
      "provider": "elevenlabs",
      "user_input_audio_format": "pcm_16000",
      "keywords": [
        "USCIS",
        "N-400",
        "A-number",
        "Naturalization",
        "Green Card"
      ]
    },
    "turn": {
      "turn_timeout": 8,
      "silence_end_call_timeout": -1,
      "mode": "turn"
    },
    "tts": {
      "model_id": "eleven_turbo_v2",
      "voice_id": "cjVigY5qzO86Huf0OWal",
      "supported_voices": [],
      "agent_output_audio_format": "pcm_16000",
      "optimize_streaming_latency": 3,
      "stability": 0.4,
      "speed": 0.96,
      "similarity_boost": 0.8,
      "pronunciation_dictionary_locators": []
    },
    "conversation": {
      "text_only": false,
      "max_duration_seconds": 1800,
      "client_events": [
        "audio",
        "interruption"
      ]
    },
    "language_presets": {},
    "agent": {
      "first_message": "Hi, I'm CitizenFlow. I'll help you complete your N-400 one step at a time, and you can talk or switch to typing whenever you want.",
      "language": "en",
      "dynamic_variables": {
        "dynamic_variable_placeholders": {}
      },
      "prompt": {
        "prompt": "You are CitizenFlow's calm, voice-first N-400 intake guide. Your job is to help the user understand and complete the supported parts of the USCIS Form N-400 accurately and patiently. Ask one focused question at a time. Use plain language. Never invent facts. Confirm sensitive details like names, dates, A-numbers, SSNs, and addresses aloud before moving on. If the user seems frustrated with speech capture, briefly remind them that they can switch to typing using the on-screen text box. If the user mentions arrests, crimes, removal, false claims to citizenship, long trips, tax problems, selective service issues, fraud, or any situation with legal risk, stay factual, explain that those situations may require careful legal review, and recommend review by an immigration attorney or accredited representative. Do not promise eligibility or approval. Follow official USCIS N-400 instructions and the attached CitizenFlow knowledge base. Keep responses concise and spoken-friendly.",
        "llm": "gemini-2.5-flash",
        "temperature": 0.2,
        "max_tokens": 1200,
        "tool_ids": [],
        "mcp_server_ids": [],
        "native_mcp_server_ids": [],
        "knowledge_base": [
          {
            "id": "6kFlrYCcIKvsXlljkcr3",
            "type": "text",
            "name": "CitizenFlow N400 Official Requirements"
          },
          {
            "id": "1Ng2KLvgOBHIviZCqSNm",
            "type": "text",
            "name": "CitizenFlow N400 Supported Scope"
          },
          {
            "id": "MRQeTSISSmt02AnQMFTn",
            "type": "text",
            "name": "CitizenFlow N400 Field Guide"
          }
        ],
        "ignore_default_personality": true,
        "rag": {
          "enabled": true,
          "embedding_model": "e5_mistral_7b_instruct",
          "max_vector_distance": 0.55,
          "max_documents_length": 50000,
          "max_retrieved_rag_chunks_count": 12
        },
        "custom_llm": null
      }
    }
  },
